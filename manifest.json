{
  "manifest_version": 3,
  "name": "ReconcileIQ Receipt Capture",
  "version": "2.0.2",
  "description": "Capture billing page invoices and send them directly to ReconcileIQ for automatic matching.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "debugger"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ReconcileIQ Receipt Capture",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "vendorProfiles.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}